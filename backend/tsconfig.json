{
  "compilerOptions": {
    /* Layout */
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    
  
    "esModuleInterop": true,
    "skipLibCheck": true,

    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true, 
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}