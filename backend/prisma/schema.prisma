generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id             String   @id @default(uuid())
  titulo         String
  descripcion    String
  estado         Boolean  @default(false)
  fecha_creacion DateTime @default(now())
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
}